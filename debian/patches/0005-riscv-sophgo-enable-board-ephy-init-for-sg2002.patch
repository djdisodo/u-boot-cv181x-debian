+	cv1800b_ephy_select_page(15);
+	writel(0x2922, cv1800b_ephy_reg(0x40));
+	writel(0x366e, cv1800b_ephy_reg(0x44));
+	writel(0x0752, cv1800b_ephy_reg(0x48));
+	writel(0x2556, cv1800b_ephy_reg(0x4c));
+	writel(0x2348, cv1800b_ephy_reg(0x50));
+	writel(0x0c30, cv1800b_ephy_reg(0x54));
+
+	cv1800b_ephy_select_page(16);
+	writel(0x1e08, cv1800b_ephy_reg(0x40));
+	writel(0x3868, cv1800b_ephy_reg(0x44));
+	writel(0x1462, cv1800b_ephy_reg(0x48));
+	writel(0x1a0e, cv1800b_ephy_reg(0x4c));
+	writel(0x305e, cv1800b_ephy_reg(0x50));
+	writel(0x2f62, cv1800b_ephy_reg(0x54));
+
+	cv1800b_ephy_select_page(1);
+	writel(readl(cv1800b_ephy_reg(0x68)) & ~0x0f00, cv1800b_ephy_reg(0x68));
+
+	cv1800b_ephy_select_page(19);
+	writel(0x0012, cv1800b_ephy_reg(0x58));
+	writel(0x6848, cv1800b_ephy_reg(0x5c));
+
+	cv1800b_ephy_select_page(18);
+	cv1800b_ephy_write_page18_filter();
+
+	cv1800b_ephy_select_page(0);
+	writel(0x090e, REG_EPHY_CTL);
+	writel(readl(cv1800b_ephy_reg(0x00)) | 0x0100, cv1800b_ephy_reg(0x00));
+
+	/* switch to MDIO control */
+	writel(0, REG_EPHY_APB_RW_SEL);
+
+	/* Route the internal PHY LED outputs to the board pads. */
+	writel(0x05, REG_EPHY_LED_PAD_MUX0);
+	writel(0x05, REG_EPHY_LED_PAD_MUX1);
+	writel(0x11111111, REG_EPHY_LED_PAD_SEL0);
+	writel(0x11111111, REG_EPHY_LED_PAD_SEL1);
+}
