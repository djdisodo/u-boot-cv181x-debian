From 3f0d58ed2e6d2f3c5c780e403eb782ef4064da42 Mon Sep 17 00:00:00 2001
From: Packaging Maintainer <maintainer@example.com>
Date: Sat, 6 Jun 2026 11:20:00 +0900
Subject: [PATCH] riscv: sophgo: move cv18xx ephy defaults into board init

The current SG2002 Debian packages use upstream DTS-only Ethernet enablement,
which assumes the board-specific internal EPHY setup has already happened in
firmware/U-Boot. Our shipped defconfigs disable BOARD_INIT and the Nano board
code does not wire in the existing cv1800b_ephy_init() helper, so that setup
never runs.

Enable BOARD_INIT for both packaged defconfigs and add the same EPHY
initialization path to the Nano board implementation that the Milk-V Duo
board already uses. Extend that shared helper with the downstream CV18xx
default analog tuning sequence so both packaged boards present a fully
initialized internal RMII PHY before Linux falls back to the generic PHY
driver.
---
--- a/board/sophgo/licheerv_nano/Makefile
+++ b/board/sophgo/licheerv_nano/Makefile
@@ -3,3 +3,4 @@
 # Copyright (c) 2024, Kongyang Liu <seashell11234455@gmail.com>
 
 obj-y += board.o
+obj-$(CONFIG_NET) += ethernet.o
--- a/board/sophgo/licheerv_nano/board.c
+++ b/board/sophgo/licheerv_nano/board.c
@@ -3,3 +3,18 @@
  * Copyright (c) 2024, Kongyang Liu <seashell11234455@gmail.com>
  */
 
+#include <dm/lists.h>
+
+#include "ethernet.h"
+
+int board_init(void)
+{
+	if (IS_ENABLED(CONFIG_SYSRESET_CV1800B))
+		device_bind_driver(gd->dm_root, "cv1800b_sysreset", "sysreset",
+				   NULL);
+
+	if (IS_ENABLED(CONFIG_NET))
+		cv1800b_ephy_init();
+
+	return 0;
+}
