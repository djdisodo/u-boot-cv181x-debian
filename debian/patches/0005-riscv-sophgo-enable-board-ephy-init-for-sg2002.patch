From 3f0d58ed2e6d2f3c5c780e403eb782ef4064da42 Mon Sep 17 00:00:00 2001
From: Packaging Maintainer <maintainer@example.com>
Date: Sat, 6 Jun 2026 11:20:00 +0900
Subject: [PATCH] riscv: sophgo: enable board ephy init for sg2002 builds

The current SG2002 Debian packages use upstream DTS-only Ethernet enablement,
which assumes the board-specific internal EPHY setup has already happened in
firmware/U-Boot. Our shipped defconfigs disable BOARD_INIT and the Nano board
code does not wire in the existing cv1800b_ephy_init() helper, so that setup
never runs.

Enable BOARD_INIT for both packaged defconfigs and add the same EPHY
initialization path to the Nano board implementation that the Milk-V Duo
board already uses. Also refresh the shared helper so both packaged boards
mirror the vendor U-Boot bring-up sequence more closely by seeding the
vendor PHY ID and routing the integrated PHY LED outputs.
---
--- a/board/sophgo/licheerv_nano/Makefile
+++ b/board/sophgo/licheerv_nano/Makefile
@@ -3,3 +3,4 @@
 # Copyright (c) 2024, Kongyang Liu <seashell11234455@gmail.com>
 
 obj-y += board.o
+obj-$(CONFIG_NET) += ethernet.o
--- a/board/sophgo/licheerv_nano/board.c
+++ b/board/sophgo/licheerv_nano/board.c
@@ -3,3 +3,18 @@
  * Copyright (c) 2024, Kongyang Liu <seashell11234455@gmail.com>
  */
 
+#include <dm/lists.h>
+
+#include "ethernet.h"
+
+int board_init(void)
+{
+	if (IS_ENABLED(CONFIG_SYSRESET_CV1800B))
+		device_bind_driver(gd->dm_root, "cv1800b_sysreset", "sysreset",
+				   NULL);
+
+	if (IS_ENABLED(CONFIG_NET))
+		cv1800b_ephy_init();
+
+	return 0;
+}
--- a/board/sophgo/milkv_duo/ethernet.c
+++ b/board/sophgo/milkv_duo/ethernet.c
@@ -4,76 +4,53 @@
  */
 
 #include <linux/io.h>
-#include <linux/bitops.h>
 #include <linux/mii.h>
 
-#define REG_EPHY_TOP_WRAP (u32 *)0x03009800
-#define REG_EPHY_BASE     (u32 *)0x03009000
+#define REG_EPHY_TOP_WRAP	((u32 *)0x03009800)
+#define REG_EPHY_BASE		((u32 *)0x03009000)
+#define REG_EPHY_LED_PAD_MUX0	((u32 *)0x0300109c)
+#define REG_EPHY_LED_PAD_MUX1	((u32 *)0x030010a0)
+#define REG_EPHY_LED_PAD_SEL0	((u32 *)0x050270b0)
+#define REG_EPHY_LED_PAD_SEL1	((u32 *)0x050270b4)
 
-#define REG_EPHY_CTL         REG_EPHY_TOP_WRAP
-#define REG_EPHY_APB_RW_SEL  REG_EPHY_TOP_WRAP + 1
+#define REG_EPHY_CTL		REG_EPHY_TOP_WRAP
+#define REG_EPHY_APB_RW_SEL	(REG_EPHY_TOP_WRAP + 1)
 
 /* Page 0 register */
-#define REG_PHY_ID1          REG_EPHY_BASE + MII_PHYSID1
-#define REG_PHY_ID2          REG_EPHY_BASE + MII_PHYSID2
-#define REG_PHY_PAGE_SEL     REG_EPHY_BASE + 0x1f
+#define REG_PHY_ID1		(REG_EPHY_BASE + MII_PHYSID1)
+#define REG_PHY_ID2		(REG_EPHY_BASE + MII_PHYSID2)
+#define REG_PHY_PAGE_SEL	(REG_EPHY_BASE + 0x1f)
 
 /* Page 5 register */
-#define REG_PD_EN_CTL        REG_EPHY_BASE + 0x10
-
-/* REG_EPHY_CTL */
-#define REG_EPHY_SHUTDOWN    BIT(0)
-#define REG_EPHY_ANA_RST_N   BIT(1)
-#define REG_EPHY_DIG_RST_N   BIT(2)
-#define REG_EPHY_MAIN_RST_N  BIT(3)
-
-/* REG_PD_EN_CTL */
-#define REG_EN_ETH_TXRT          BIT(0)
-#define REG_EN_ETH_CLK100M       BIT(1)
-#define REG_EN_ETH_CLK125M       BIT(2)
-#define REG_EN_ETH_PLL_LCKDET    BIT(3)
-#define REG_EN_ETH_RXADC         BIT(4)
-#define REG_EN_ETH_RXPGA         BIT(5)
-#define REG_EN_ETH_RXRT          BIT(6)
-#define REG_EN_ETH_TXCROSSOVER   BIT(7)
-#define REG_PD_ETH_PLL           BIT(8)
-#define REG_PD_ETH_TXDAC         BIT(9)
-#define REG_PD_ETH_TXDACBST      BIT(10)
-#define REG_PD_ETH_TXECHO        BIT(11)
-#define REG_PD_ETH_TXDRV_NMOS    BIT(12)
-#define REG_PD_ETH_TXLDO         BIT(13)
+#define REG_PD_EN_CTL		(REG_EPHY_BASE + 0x10)
 
 void cv1800b_ephy_init(void)
 {
-	u32 reg;
-	u32 phy_id = 1;
-
 	/* enable direct memory access for phy register */
 	writel(1, REG_EPHY_APB_RW_SEL);
 
-	reg = readl(REG_EPHY_CTL);
-	reg &= ~REG_EPHY_SHUTDOWN;
-	reg |= REG_EPHY_ANA_RST_N | REG_EPHY_DIG_RST_N | REG_EPHY_MAIN_RST_N;
-	writel(reg, REG_EPHY_CTL);
+	/* Match the downstream CV18xx U-Boot internal EPHY bring-up order. */
+	writel(0x0900, REG_EPHY_CTL);
+	writel(0x0904, REG_EPHY_CTL);
 
 	/* switch to page 5 */
-	writel(5 << 8, REG_PHY_PAGE_SEL);
-	reg = readl(REG_PD_EN_CTL);
-	reg &= ~(REG_PD_ETH_TXLDO | REG_PD_ETH_TXDRV_NMOS | REG_PD_ETH_TXDAC | REG_PD_ETH_PLL);
-	reg |= REG_EN_ETH_TXRT | REG_EN_ETH_CLK100M | REG_EN_ETH_CLK125M
-		| REG_EN_ETH_PLL_LCKDET | REG_EN_ETH_RXADC | REG_EN_ETH_RXPGA | REG_EN_ETH_RXRT;
-	writel(reg, REG_PD_EN_CTL);
+	writel(0x0500, REG_PHY_PAGE_SEL);
+	writel(0x0c00, REG_PD_EN_CTL);
+	writel(0x0c7e, REG_PD_EN_CTL);
 
-	/* switch to page 0 */
-	writel(0 << 8, REG_PHY_PAGE_SEL);
-	/*
-	 * As the phy_id in the cv1800b PHY register is initialized to 0, it
-	 * is necessary to manually initialize the phy_id to an arbitrary
-	 * value so that it could corresponds to the generic PHY driver.
-	 */
-	writel(phy_id >> 16, REG_PHY_ID1);
-	writel(phy_id & 0xffff, REG_PHY_ID2);
+	writel(0x0906, REG_EPHY_CTL);
+	writel(0x0500, REG_PHY_PAGE_SEL);
+
+	/* Seed the vendor PHY ID expected by the downstream CVITEK PHY driver. */
+	writel(0x0043, REG_PHY_ID1);
+	writel(0x5649, REG_PHY_ID2);
 
 	/* switch to MDIO control */
 	writel(0, REG_EPHY_APB_RW_SEL);
+
+	/* Route the internal PHY LED outputs to the board pads. */
+	writel(0x05, REG_EPHY_LED_PAD_MUX0);
+	writel(0x05, REG_EPHY_LED_PAD_MUX1);
+	writel(0x11111111, REG_EPHY_LED_PAD_SEL0);
+	writel(0x11111111, REG_EPHY_LED_PAD_SEL1);
 }
--- /dev/null
+++ b/board/sophgo/licheerv_nano/ethernet.c
@@ -0,0 +1,52 @@
+// SPDX-License-Identifier: GPL-2.0+
+/*
+ * Copyright (c) 2024, Kongyang Liu <seashell11234455@gmail.com>
+ */
+
+#include <linux/io.h>
+#include <linux/mii.h>
+
+#define REG_EPHY_TOP_WRAP	((u32 *)0x03009800)
+#define REG_EPHY_BASE		((u32 *)0x03009000)
+#define REG_EPHY_LED_PAD_MUX0	((u32 *)0x0300109c)
+#define REG_EPHY_LED_PAD_MUX1	((u32 *)0x030010a0)
+#define REG_EPHY_LED_PAD_SEL0	((u32 *)0x050270b0)
+#define REG_EPHY_LED_PAD_SEL1	((u32 *)0x050270b4)
+
+#define REG_EPHY_CTL		REG_EPHY_TOP_WRAP
+#define REG_EPHY_APB_RW_SEL	(REG_EPHY_TOP_WRAP + 1)
+
+/* Page 0 register */
+#define REG_PHY_ID1		(REG_EPHY_BASE + MII_PHYSID1)
+#define REG_PHY_ID2		(REG_EPHY_BASE + MII_PHYSID2)
+#define REG_PHY_PAGE_SEL	(REG_EPHY_BASE + 0x1f)
+
+/* Page 5 register */
+#define REG_PD_EN_CTL		(REG_EPHY_BASE + 0x10)
+
+void cv1800b_ephy_init(void)
+{
+	/* enable direct memory access for phy register */
+	writel(1, REG_EPHY_APB_RW_SEL);
+
+	/* Match the downstream CV18xx U-Boot internal EPHY bring-up order. */
+	writel(0x0900, REG_EPHY_CTL);
+	writel(0x0904, REG_EPHY_CTL);
+
+	/* switch to page 5 */
+	writel(0x0500, REG_PHY_PAGE_SEL);
+	writel(0x0c00, REG_PD_EN_CTL);
+	writel(0x0c7e, REG_PD_EN_CTL);
+
+	writel(0x0906, REG_EPHY_CTL);
+	writel(0x0500, REG_PHY_PAGE_SEL);
+
+	/* Seed the vendor PHY ID expected by the downstream CVITEK PHY driver. */
+	writel(0x0043, REG_PHY_ID1);
+	writel(0x5649, REG_PHY_ID2);
+
+	/* switch to MDIO control */
+	writel(0, REG_EPHY_APB_RW_SEL);
+
+	/* Route the internal PHY LED outputs to the board pads. */
+	writel(0x05, REG_EPHY_LED_PAD_MUX0);
+	writel(0x05, REG_EPHY_LED_PAD_MUX1);
+	writel(0x11111111, REG_EPHY_LED_PAD_SEL0);
+	writel(0x11111111, REG_EPHY_LED_PAD_SEL1);
+}
--- /dev/null
+++ b/board/sophgo/licheerv_nano/ethernet.h
@@ -0,0 +1,11 @@
+/* SPDX-License-Identifier: GPL-2.0+ */
+/*
+ * Copyright (c) 2024, Kongyang Liu <seashell11234455@gmail.com>
+ */
+
+#ifndef __CV1800B_ETHERNET_H
+#define __CV1800B_ETHERNET_H
+
+void cv1800b_ephy_init(void);
+
+#endif
--- a/configs/sg2002_milkv_duo256m_defconfig
+++ b/configs/sg2002_milkv_duo256m_defconfig
@@ -19,7 +19,7 @@
 CONFIG_BOOTCOMMAND="run distro_bootcmd"
 CONFIG_SYS_CBSIZE=512
 CONFIG_SYS_PBSIZE=544
-# CONFIG_BOARD_INIT is not set
+CONFIG_BOARD_INIT=y
 CONFIG_SYS_PROMPT="sg2002_milkv_duo256m# "
 # CONFIG_CMD_BOOTDEV is not set
 CONFIG_CMD_MBR=y
--- a/configs/sipeed_licheerv_nano_defconfig
+++ b/configs/sipeed_licheerv_nano_defconfig
@@ -17,7 +17,7 @@
 CONFIG_SD_BOOT=y
 CONFIG_BOOTCOMMAND="run distro_bootcmd"
 CONFIG_SYS_CBSIZE=512
 CONFIG_SYS_PBSIZE=544
-# CONFIG_BOARD_INIT is not set
+CONFIG_BOARD_INIT=y
 CONFIG_SYS_PROMPT="licheerv_nano# "
 # CONFIG_CMD_BOOTDEV is not set
 CONFIG_CMD_MBR=y
