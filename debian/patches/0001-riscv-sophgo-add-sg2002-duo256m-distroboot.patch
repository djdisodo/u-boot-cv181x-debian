From 29fca84ae5fc61a128e8f927230690b1d6f2055a Mon Sep 17 00:00:00 2001
From: Recipe Maintainer <maintainer@example.com>
Date: Tue, 7 Apr 2026 05:04:25 +0900
Subject: [PATCH 1/2] riscv: sophgo: add sg2002 duo256m distroboot defconfig
 and dtb

---
 arch/riscv/dts/Makefile                 |  1 +
 arch/riscv/dts/sg2002-milkv-duo256m.dts | 46 ++++++++++++++++++++
 configs/sg2002_milkv_duo256m_defconfig  | 57 +++++++++++++++++++++++++
 3 files changed, 104 insertions(+)
 create mode 100644 arch/riscv/dts/sg2002-milkv-duo256m.dts
 create mode 100644 configs/sg2002_milkv_duo256m_defconfig

diff --git a/arch/riscv/dts/Makefile b/arch/riscv/dts/Makefile
index 9b347fc3b50..cdebba34e92 100644
--- a/arch/riscv/dts/Makefile
+++ b/arch/riscv/dts/Makefile
@@ -7,6 +7,7 @@ dtb-$(CONFIG_TARGET_K230_CANMV) += k230-canmv.dtb
 dtb-$(CONFIG_TARGET_MICROCHIP_ICICLE) += mpfs-icicle-kit.dtb
 dtb-$(CONFIG_TARGET_MILKV_DUO) += cv1800b-milkv-duo.dtb
 dtb-$(CONFIG_TARGET_LICHEERV_NANO) += sg2002-licheerv-nano-b.dtb
+dtb-$(CONFIG_TARGET_LICHEERV_NANO) += sg2002-milkv-duo256m.dtb
 dtb-$(CONFIG_TARGET_QEMU_VIRT) += qemu-virt32.dtb qemu-virt64.dtb
 dtb-$(CONFIG_TARGET_OPENPITON_RISCV64) += openpiton-riscv64.dtb
 dtb-$(CONFIG_TARGET_SIFIVE_UNLEASHED) += hifive-unleashed-a00.dtb
diff --git a/arch/riscv/dts/sg2002-milkv-duo256m.dts b/arch/riscv/dts/sg2002-milkv-duo256m.dts
new file mode 100644
index 00000000000..2133b48146d
--- /dev/null
+++ b/arch/riscv/dts/sg2002-milkv-duo256m.dts
@@ -0,0 +1,46 @@
+// SPDX-License-Identifier: (GPL-2.0 OR MIT)
+/*
+ * SG2002 Milk-V Duo 256M U-Boot DT
+ */
+
+/dts-v1/;
+
+#include "sg2002.dtsi"
+
+/ {
+	model = "Milk-V Duo 256M";
+	compatible = "milkv,duo256m", "sophgo,sg2002";
+
+	aliases {
+		gpio0 = &gpio0;
+		gpio1 = &gpio1;
+		gpio2 = &gpio2;
+		gpio3 = &gpio3;
+		serial0 = &uart0;
+		serial1 = &uart1;
+		serial2 = &uart2;
+		serial3 = &uart3;
+		serial4 = &uart4;
+	};
+
+	chosen {
+		stdout-path = "serial0:115200n8";
+	};
+};
+
+&osc {
+	clock-frequency = <25000000>;
+};
+
+&sdhci0 {
+	status = "okay";
+	bus-width = <4>;
+	no-1-8-v;
+	no-mmc;
+	no-sdio;
+};
+
+&uart0 {
+	status = "okay";
+};
+
diff --git a/configs/sg2002_milkv_duo256m_defconfig b/configs/sg2002_milkv_duo256m_defconfig
new file mode 100644
index 00000000000..38a5c28713b
--- /dev/null
+++ b/configs/sg2002_milkv_duo256m_defconfig
@@ -0,0 +1,57 @@
+CONFIG_RISCV=y
+CONFIG_SYS_MALLOC_LEN=0x820000
+CONFIG_SYS_MALLOC_F_LEN=0x8000
+CONFIG_NR_DRAM_BANKS=1
+CONFIG_HAS_CUSTOM_SYS_INIT_SP_ADDR=y
+CONFIG_CUSTOM_SYS_INIT_SP_ADDR=0x82300000
+CONFIG_DEFAULT_DEVICE_TREE="sg2002-milkv-duo256m"
+CONFIG_SYS_LOAD_ADDR=0x80080000
+CONFIG_IDENT_STRING="sg2002_milkv_duo256m"
+CONFIG_TARGET_LICHEERV_NANO=y
+CONFIG_ARCH_RV64I=y
+CONFIG_RISCV_SMODE=y
+CONFIG_FIT=y
+CONFIG_BOOTSTD_FULL=y
+# CONFIG_BOOTMETH_EFI_BOOTMGR is not set
+CONFIG_SD_BOOT=y
+CONFIG_USE_PREBOOT=y
+CONFIG_PREBOOT="if test -z \"${fdt_addr_r}\"; then setenv fdt_addr_r 0x83f00000; fi; if test -z \"${fdtoverlay_addr_r}\"; then setenv fdtoverlay_addr_r 0x84000000; fi; mmc dev 0; if load mmc 0:1 ${fdt_addr_r} /dtb/sg2002-milkv-duo256m.dtb; then fdt addr ${fdt_addr_r}; fdt resize 0x2000; if load mmc 0:1 ${fdtoverlay_addr_r} /overlays/user.dtbo; then fdt apply ${fdtoverlay_addr_r}; fi; setenv fdt_addr ${fdt_addr_r}; fi"
+CONFIG_BOOTCOMMAND="run distro_bootcmd"
+CONFIG_SYS_CBSIZE=512
+CONFIG_SYS_PBSIZE=544
+# CONFIG_BOARD_INIT is not set
+CONFIG_SYS_PROMPT="sg2002_milkv_duo256m# "
+# CONFIG_CMD_BOOTDEV is not set
+CONFIG_CMD_MBR=y
+CONFIG_CMD_MMC=y
+CONFIG_CMD_POWEROFF=y
+# CONFIG_CMD_MII is not set
+CONFIG_CMD_LOADB=y
+CONFIG_CMD_LOADS=y
+CONFIG_CMD_LOADXY_TIMEOUT=600
+CONFIG_CMD_SYSBOOT=y
+CONFIG_CMD_EXT4_WRITE=y
+CONFIG_CMD_FAT=y
+CONFIG_CMD_FS_GENERIC=y
+CONFIG_CMD_FDT=y
+# CONFIG_ISO_PARTITION is not set
+# CONFIG_EFI_PARTITION is not set
+CONFIG_ENV_OVERWRITE=y
+CONFIG_NET_RANDOM_ETHADDR=y
+CONFIG_CLK_SOPHGO_CV1800B=y
+CONFIG_MMC=y
+CONFIG_MMC_IO_VOLTAGE=y
+CONFIG_MMC_UHS_SUPPORT=y
+CONFIG_MMC_SDHCI=y
+CONFIG_MMC_SDHCI_ADMA=y
+CONFIG_MMC_SDHCI_CV1800B=y
+CONFIG_SPI_FLASH_MACRONIX=y
+CONFIG_ETH_DESIGNWARE=y
+CONFIG_SYS_NS16550=y
+CONFIG_SYS_NS16550_MEM32=y
+CONFIG_SPI=y
+CONFIG_CV1800B_SPIF=y
+CONFIG_SYSRESET=y
+CONFIG_SYSRESET_CV1800B=y
+CONFIG_OF_LIBFDT_OVERLAY=y
+
-- 
