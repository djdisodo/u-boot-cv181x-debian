 CONFIG_ARCH_RV64I=y
@@ -45,3 +46,4 @@
 CONFIG_CV1800B_SPIF=y
 CONFIG_SYSRESET=y
 CONFIG_SYSRESET_CV1800B=y
+CONFIG_OF_LIBFDT_OVERLAY=y
--- a/include/configs/licheerv_nano.h
+++ b/include/configs/licheerv_nano.h
@@ -14,10 +14,17 @@
 
 #define CFG_SYS_SDRAM_BASE         0x80000000
 
+#ifndef CONFIG_DEFAULT_FDT_FILE
+#define CONFIG_DEFAULT_FDT_FILE CONFIG_DEFAULT_DEVICE_TREE ".dtb"
+#endif
+
 #define CFG_EXTRA_ENV_SETTINGS  "consoledev=ttyS0\0" \
 								"baudrate=115200\0" \
 								"fdt_addr_r=0x82000000\0" \
+								"fdtoverlay_addr_r=0x84000000\0" \
+								"fdtfile=" CONFIG_DEFAULT_FDT_FILE "\0" \
 								"kernel_addr_r=0x81000000\0" \
+								"ramdisk_addr_r=0x85000000\0" \
 								"scriptaddr=0x80c00000\0" \
 								BOOTENV
