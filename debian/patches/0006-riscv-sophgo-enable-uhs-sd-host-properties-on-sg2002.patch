Description: add safe vendor-style SD host defaults to SG2002 distroboot DTBs
Author: Packaging Maintainer <maintainer@example.com>
Forwarded: not-yet

--- a/arch/riscv/dts/sg2002-licheerv-nano-b.dts
+++ b/arch/riscv/dts/sg2002-licheerv-nano-b.dts
@@ -35,9 +35,13 @@
 &sdhci0 {
 	status = "okay";
 	bus-width = <4>;
+	src-frequency = <375000000>;
+	min-frequency = <400000>;
+	max-frequency = <200000000>;
+	reset_tx_rx_phy;
 	no-1-8-v;
 	no-mmc;
 	no-sdio;
 };
 
