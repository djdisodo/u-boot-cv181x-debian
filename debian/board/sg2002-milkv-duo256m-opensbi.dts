/*
 * OpenSBI DT for the Milk-V Duo 256M.
 *
 * Base SoC content comes from upstream Linux DTS sources vendored under
 * board/kernel-upstream. The reset nodes below are carried locally until
 * the upstream kernel reset binding lands.
 */

/dts-v1/;

#include "sg2002.dtsi"

/ {
	model = "Milk-V Duo 256M";
	compatible = "milkv,duo256m", "sophgo,sg2002";

	aliases {
		gpio0 = &gpio0;
		gpio1 = &gpio1;
		gpio2 = &gpio2;
		gpio3 = &gpio3;
		serial0 = &uart0;
		serial1 = &uart1;
		serial2 = &uart2;
		serial3 = &uart3;
		serial4 = &uart4;
	};

	chosen {
		stdout-path = "serial0:115200n8";
	};

	soc-reset {
		compatible = "sophgo,cv1800-reset";
		sophgo,rtcsys = <&rtc>;
	};
};

&osc {
	clock-frequency = <25000000>;
};

&sdhci0 {
	status = "okay";
	bus-width = <4>;
	no-1-8-v;
	no-mmc;
	no-sdio;
};

&uart0 {
	status = "okay";
};
